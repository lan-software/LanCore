APP_NAME=LanCore
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Generate with: vendor/bin/sail artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=infrastructure-pgsql
DB_PORT=5432
DB_DATABASE=lancore
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Semantic storage roles. Each may point to: local, public, s3, s3_public, s3_private
FILESYSTEM_PUBLIC_DISK=public
FILESYSTEM_PRIVATE_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

REDIS_CLIENT=phpredis
REDIS_HOST=infrastructure-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=infrastructure-mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=garage
AWS_BUCKET=lancore
AWS_ENDPOINT=http://garage:3900
AWS_URL=http://localhost:3900
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ANONYMOUS_BUCKET_ACCESS=false

# Optional split-bucket S3. Each AWS_PUBLIC_*/AWS_PRIVATE_* var falls back to its
# AWS_* counterpart, so you only need to set what differs (typically just the bucket).
# AWS_PUBLIC_BUCKET=lancore-public
# AWS_PUBLIC_URL=
# AWS_PUBLIC_ENDPOINT=
# AWS_PUBLIC_ACCESS_KEY_ID=
# AWS_PUBLIC_SECRET_ACCESS_KEY=
# AWS_PUBLIC_DEFAULT_REGION=
# AWS_PUBLIC_USE_PATH_STYLE_ENDPOINT=
# AWS_PUBLIC_ANONYMOUS_BUCKET_ACCESS=
# AWS_PRIVATE_BUCKET=lancore-private
# AWS_PRIVATE_URL=
# AWS_PRIVATE_ENDPOINT=
# AWS_PRIVATE_ACCESS_KEY_ID=
# AWS_PRIVATE_SECRET_ACCESS_KEY=
# AWS_PRIVATE_DEFAULT_REGION=
# AWS_PRIVATE_USE_PATH_STYLE_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"

# Signed ticket tokens (Phase A). Generate keys via `php artisan tickets:keys:rotate`.
TICKET_SIGNED_TOKENS_ENABLED=false
TICKET_TOKEN_PEPPER=
TICKET_SIGNING_ACTIVE_KID=
TICKET_SIGNING_VERIFY_KIDS=
