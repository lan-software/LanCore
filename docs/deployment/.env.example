# Application
APP_NAME=LanCore
APP_KEY=             # Generate with: docker run --rm php:8.5-alpine php -r "echo 'base64:'.base64_encode(random_bytes(32));"
APP_URL=https://your-domain.com
APP_TIMEZONE=UTC
APP_LOCALE=en

# Logging
LOG_LEVEL=error

# Database (PostgreSQL)
DB_DATABASE=lancore
DB_USERNAME=lancore
DB_PASSWORD=

# Redis
REDIS_PASSWORD=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME=LanCore

# S3 / MinIO Object Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=lancore
AWS_ENDPOINT=http://minio:9000
AWS_URL=https://your-domain.com/storage

# Semantic storage roles — choose where public assets and sensitive files live.
# Recommended for production: split into two buckets via s3_public / s3_private.
FILESYSTEM_PUBLIC_DISK=s3_public
FILESYSTEM_PRIVATE_DISK=s3_private
# Per-role bucket overrides (each var falls back to AWS_* if unset).
AWS_PUBLIC_BUCKET=lancore-public
AWS_PRIVATE_BUCKET=lancore-private
# AWS_PUBLIC_URL=
# AWS_PRIVATE_URL=

# Ports (optional overrides)
APP_PORT=80
MINIO_CONSOLE_PORT=9001

# Stripe (Cashier)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
